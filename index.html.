    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --orange: #F05C14;
            --orange-dark: #C44A0A;
            --orange-light: #FFF3EC;
            --orange-mid: rgba(240,92,20,0.12);
            --ink: #000000;
            --ink-mid: #111827;
            --ink-soft: #374151;
            --cream: #FDFCFA;
            --white: #FFFFFF;
            --line: #E8E4DC;
            --green: #15803D;
            --green-bg: #F0FDF4;
            --green-border: rgba(21,128,61,0.2);
            --red: #DC2626;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--ink);
            font-weight: 500;
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* Grain */
        body::after {
            content: '';
            position: fixed; inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='0.025'/%3E%3C/svg%3E");
            pointer-events: none; z-index: 9999; opacity: 0.5;
        }

        /* Blob */
        .blob {
            position: fixed;
            width: 800px; height: 800px; border-radius: 50%;
            background: radial-gradient(circle at center, rgba(240,92,20,0.07) 0%, transparent 68%);
            top: -200px; right: -200px;
            pointer-events: none; z-index: 0;
        }

        /* ── PAGE GRID ── */
        .page {
            position: relative; z-index: 1;
            display: grid;
            grid-template-columns: 1fr 520px;
            min-height: 100vh;
        }

        /* ── LEFT ── */
        .left {
            padding: 36px 52px 52px;
            display: flex; flex-direction: column;
            border-right: 1px solid var(--line);
        }

        .logo {
            display: inline-flex; align-items: center; gap: 10px;
            text-decoration: none; margin-bottom: 56px;
        }

        .logo-mark {
            width: 36px; height: 36px;
            background: var(--orange); border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
        }

        .logo-mark svg { width: 20px; height: 20px; }

        .logo-name {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-weight: 700; font-size: 1.1rem;
            color: var(--ink); letter-spacing: -0.02em;
        }

        .left-body { flex: 1; display: flex; flex-direction: column; justify-content: center; max-width: 460px; }

        .pill {
            display: inline-flex; align-items: center; gap: 7px;
            background: var(--orange-light);
            border: 1px solid rgba(240,92,20,0.25);
            border-radius: 100px; padding: 5px 13px;
            font-size: 0.74rem; font-weight: 600;
            color: var(--orange-dark); letter-spacing: 0.01em;
            margin-bottom: 22px; width: fit-content;
            text-transform: uppercase;
        }

        .pill-dot {
            width: 5px; height: 5px; border-radius: 50%;
            background: var(--orange);
            animation: pulse 2s ease infinite;
        }

        @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.75)} }

        .left-h1 {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-weight: 800;
            font-size: clamp(2rem, 3vw, 2.8rem);
            line-height: 1.1; letter-spacing: -0.03em;
            color: var(--ink); margin-bottom: 16px;
        }

        .left-h1 em { font-style: normal; color: var(--orange); }

        .left-sub {
            font-size: 0.97rem; color: #111827;
            line-height: 1.7; font-weight: 500;
            margin-bottom: 36px; max-width: 400px;
        }

        /* Steps list */
        .steps { display: flex; flex-direction: column; gap: 0; margin-bottom: 40px; }

        .step-row {
            display: flex; align-items: flex-start; gap: 16px;
            padding: 16px 0;
            border-bottom: 1px solid var(--line);
        }

        .step-row:first-child { border-top: 1px solid var(--line); }

        .step-num {
            width: 28px; height: 28px; min-width: 28px;
            border-radius: 50%;
            border: 1.5px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.72rem; font-weight: 700;
            color: var(--ink-soft); margin-top: 1px;
            font-family: 'Bricolage Grotesque', sans-serif;
        }

        .step-num.done {
            background: var(--green-bg);
            border-color: var(--green-border);
            color: var(--green);
        }

        .step-content-label {
            font-size: 0.82rem; font-weight: 600; color: var(--ink);
            margin-bottom: 2px;
        }

        .step-content-desc {
            font-size: 0.78rem; color: var(--ink-soft); line-height: 1.4;
        }

        /* Earning range card */
        .earn-card {
            background: var(--white);
            border: 1px solid var(--line);
            border-radius: 18px;
            padding: 20px 22px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            margin-bottom: 28px;
        }

        .earn-card-label {
            font-size: 0.72rem; font-weight: 600;
            color: var(--ink-soft); text-transform: uppercase;
            letter-spacing: 0.06em; margin-bottom: 12px;
        }

        .earn-bars { display: flex; flex-direction: column; gap: 8px; }

        .earn-bar-row { display: flex; align-items: center; gap: 10px; }

        .earn-bar-tag {
            font-size: 0.72rem; color: var(--ink-soft);
            width: 70px; flex-shrink: 0;
        }

        .earn-bar-track {
            flex: 1; height: 6px;
            background: #F0EDE8; border-radius: 100px;
            overflow: hidden;
        }

        .earn-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--orange), #FF9252);
            border-radius: 100px;
            transform-origin: left;
            animation: growBar 1s cubic-bezier(0.4,0,0.2,1) both;
        }

        @keyframes growBar { from{transform:scaleX(0)} to{transform:scaleX(1)} }

        .earn-bar-val {
            font-size: 0.72rem; font-weight: 600; color: var(--ink);
            min-width: 60px; text-align: right;
        }

        /* Trustpilot */
        .tp-row { display: flex; align-items: center; gap: 10px; }
        .tp-stars { display: flex; gap: 2px; }
        .tp-star { width: 17px; height: 17px; background: #00B67A; border-radius: 2px; display: flex; align-items: center; justify-content: center; }
        .tp-star svg { width: 10px; height: 10px; fill: white; }
        .tp-text { font-size: 0.75rem; color: var(--ink-soft); }
        .tp-text strong { color: var(--ink); }

        /* ── RIGHT / QUIZ ── */
        .right {
            background: var(--white);
            display: flex; flex-direction: column;
            position: relative;
        }

        .right-stripe {
            height: 4px;
            background: linear-gradient(90deg, var(--orange) 0%, #FF9252 100%);
            flex-shrink: 0;
        }

        .quiz-wrap {
            flex: 1;
            padding: 36px 40px 36px;
            display: flex; flex-direction: column;
            overflow-y: auto;
        }

        /* Progress */
        .prog-row {
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 28px; flex-shrink: 0;
        }

        .prog-steps { display: flex; gap: 4px; flex: 1; }

        .prog-pip {
            flex: 1; height: 4px; border-radius: 100px;
            background: #F0EDE8;
            transition: background 0.4s ease;
        }

        .prog-pip.filled { background: var(--orange); }
        .prog-pip.active { background: rgba(240,92,20,0.4); }

        .prog-label {
            font-size: 0.72rem; font-weight: 600;
            color: var(--ink-soft); white-space: nowrap;
        }

        /* Live activity ticker */
        .ticker {
            display: flex; align-items: center; gap: 8px;
            background: var(--green-bg);
            border: 1px solid var(--green-border);
            border-radius: 8px;
            padding: 7px 12px;
            font-size: 0.75rem; color: var(--green);
            font-weight: 500; margin-bottom: 24px;
            flex-shrink: 0;
            animation: fadeSlideDown 0.4s ease both;
        }

        .ticker-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--green); flex-shrink: 0;
            animation: pulse 1.5s ease infinite;
        }

        @keyframes fadeSlideDown { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }

        /* Quiz step */
        .q-step { display: none; flex-direction: column; flex: 1; }
        .q-step.active { display: flex; animation: slideIn 0.32s cubic-bezier(0.4,0,0.2,1) both; }
        .q-step.leaving { animation: slideOut 0.22s ease both; }

        @keyframes slideIn { from{opacity:0;transform:translateX(16px)} to{opacity:1;transform:translateX(0)} }
        @keyframes slideOut { from{opacity:1;transform:translateX(0)} to{opacity:0;transform:translateX(-16px)} }

        .q-number {
            font-size: 0.7rem; font-weight: 700;
            color: var(--orange); letter-spacing: 0.08em;
            text-transform: uppercase; margin-bottom: 6px;
        }

        .q-text {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-weight: 700; font-size: 1.22rem;
            letter-spacing: -0.025em; line-height: 1.3;
            color: var(--ink); margin-bottom: 6px;
        }

        .q-sub {
            font-size: 0.78rem; color: #1F2937;
            line-height: 1.5; font-weight: 500; margin-bottom: 20px;
        }

        /* Options */
        .opts { display: flex; flex-direction: column; gap: 9px; }

        .opt {
            display: grid;
            grid-template-columns: 36px 1fr auto;
            align-items: center; gap: 12px;
            padding: 13px 15px;
            background: var(--cream);
            border: 1.5px solid var(--line);
            border-radius: 11px;
            cursor: pointer;
            transition: border-color 0.15s, background 0.15s, transform 0.1s;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem; color: #000000; font-weight: 600;
            text-align: left;
        }

        .opt:hover {
            border-color: var(--orange);
            background: var(--orange-light);
            color: var(--ink);
            transform: translateX(2px);
        }

        .opt.sel {
            border-color: var(--orange);
            background: var(--orange-light);
            color: var(--ink);
        }

        .opt-icon {
            width: 36px; height: 36px;
            background: var(--white);
            border: 1px solid var(--line);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            transition: border-color 0.15s, background 0.15s;
        }

        .opt.sel .opt-icon { background: rgba(240,92,20,0.08); border-color: rgba(240,92,20,0.3); }

        .opt-icon svg { width: 16px; height: 16px; color: var(--ink-soft); }
        .opt.sel .opt-icon svg { color: var(--orange); }

        .opt-text { font-weight: 500; line-height: 1.3; }

        .opt-check {
            width: 20px; height: 20px; border-radius: 50%;
            border: 1.5px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; transition: all 0.15s;
        }

        .opt.sel .opt-check { background: var(--orange); border-color: var(--orange); }
        .opt-check svg { display: none; width: 10px; height: 10px; }
        .opt.sel .opt-check svg { display: block; }

        /* Reaction */
        .reaction {
            display: none; align-items: flex-start; gap: 9px;
            background: var(--green-bg); border: 1px solid var(--green-border);
            border-radius: 9px; padding: 10px 13px;
            margin-top: 12px;
            font-size: 0.8rem; color: var(--green); line-height: 1.5;
            font-weight: 500;
        }

        .reaction.show { display: flex; animation: fadeSlideDown 0.3s ease both; }

        .reaction-icon { width: 14px; height: 14px; flex-shrink: 0; margin-top: 1px; }

        /* Earn indicator */
        .earn-indicator {
            display: none;
            align-items: center; justify-content: space-between;
            background: var(--orange-light);
            border: 1px solid rgba(240,92,20,0.2);
            border-radius: 9px; padding: 9px 13px;
            margin-top: 8px;
        }

        .earn-indicator.show { display: flex; animation: fadeSlideDown 0.3s 0.15s ease both; }

        .earn-ind-label { font-size: 0.75rem; color: var(--orange-dark); font-weight: 500; }

        .earn-ind-val {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-weight: 800; font-size: 1rem;
            color: var(--orange); letter-spacing: -0.02em;
        }

        /* Next button */
        .btn-next {
            width: 100%; margin-top: 18px;
            background: var(--orange); color: white;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem; font-weight: 600;
            padding: 13px 20px; border: none; border-radius: 11px;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            box-shadow: 0 4px 14px rgba(240,92,20,0.28);
            transition: background 0.2s, transform 0.15s, opacity 0.2s, box-shadow 0.2s;
            opacity: 0.38; pointer-events: none;
        }

        .btn-next.on { opacity: 1; pointer-events: all; }
        .btn-next.on:hover { background: var(--orange-dark); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(240,92,20,0.36); }
        .btn-next svg { width: 16px; height: 16px; transition: transform 0.2s; }
        .btn-next.on:hover svg { transform: translateX(3px); }

        /* ── REVEAL ── */
        .reveal { display: none; flex-direction: column; }
        .reveal.active { display: flex; animation: slideIn 0.4s ease both; }

        .reveal-head {
            text-align: center; padding: 4px 0 20px;
        }

        .reveal-badge {
            width: 80px; height: 80px; border-radius: 50%;
            background: linear-gradient(135deg, #FFF0E6, #FDDCC4);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 14px;
            box-shadow: 0 0 0 8px rgba(240,92,20,0.08);
        }

        .reveal-badge svg { width: 36px; height: 36px; color: var(--orange); }

        .reveal-h {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-weight: 800; font-size: 1.4rem;
            letter-spacing: -0.03em; color: var(--ink);
            margin-bottom: 5px;
        }

        .reveal-h .amt { color: var(--orange); font-size: 1.9rem; }

        .reveal-sub {
            font-size: 0.8rem; color: var(--ink-soft); line-height: 1.5;
            max-width: 300px; margin: 0 auto;
        }

        /* Breakdown */
        .breakdown {
            background: var(--cream);
            border: 1px solid var(--line);
            border-radius: 14px; padding: 14px 18px;
            margin: 16px 0;
        }

        .bk-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: 5px 0; font-size: 0.8rem;
        }

        .bk-label { color: var(--ink-soft); }
        .bk-val { font-weight: 600; color: var(--orange); }
        .bk-divider { height: 1px; background: var(--line); margin: 7px 0; }
        .bk-total { display: flex; justify-content: space-between; font-size: 0.88rem; font-weight: 700; color: var(--ink); }
        .bk-total-val { font-family: 'Bricolage Grotesque', sans-serif; font-size: 1rem; color: var(--orange); }

        /* Disclaimer */
        .disclaimer {
            background: #FFFBEB;
            border: 1px solid rgba(217,119,6,0.25);
            border-radius: 9px; padding: 10px 13px;
            font-size: 0.73rem; color: #92400E;
            line-height: 1.5; margin-bottom: 16px;
            display: flex; gap: 8px; align-items: flex-start;
        }

        .disclaimer svg { width: 13px; height: 13px; flex-shrink: 0; margin-top: 1px; color: #D97706; }

        /* Matched surveys */
        .match-label {
            font-size: 0.7rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.07em;
            color: var(--ink-soft); margin-bottom: 10px;
        }

        .survey-cards { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }

        .survey-card {
            display: flex; align-items: center; gap: 12px;
            background: var(--white);
            border: 1px solid var(--line);
            border-radius: 10px; padding: 11px 14px;
        }

        .survey-card-icon {
            width: 34px; height: 34px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }

        .survey-card-icon svg { width: 17px; height: 17px; }

        .survey-card-body { flex: 1; }
        .survey-card-name { font-size: 0.8rem; font-weight: 600; color: var(--ink); }
        .survey-card-meta { font-size: 0.72rem; color: var(--ink-soft); margin-top: 1px; }

        .survey-card-earn {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-weight: 800; font-size: 0.95rem;
            color: var(--orange); letter-spacing: -0.02em;
            text-align: right;
        }

        .survey-card-earn span { display: block; font-size: 0.65rem; font-weight: 400; color: var(--ink-soft); font-family: 'DM Sans', sans-serif; letter-spacing: 0; }

        /* Reg form */
        .reg-note { font-size: 0.78rem; color: var(--ink-soft); text-align: center; margin-bottom: 10px; }
        .reg-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }

        .reg-input {
            width: 100%; padding: 11px 13px;
            border: 1.5px solid var(--line); border-radius: 10px;
            font-family: 'DM Sans', sans-serif; font-size: 0.88rem;
            color: var(--ink); background: var(--white);
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .reg-input::placeholder { color: var(--ink-soft); }
        .reg-input:focus { outline: none; border-color: var(--orange); box-shadow: 0 0 0 3px rgba(240,92,20,0.08); }
        .reg-input.err { border-color: var(--red); box-shadow: 0 0 0 3px rgba(220,38,38,0.08); }

        .btn-claim {
            width: 100%; background: var(--orange); color: white;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.97rem; font-weight: 700;
            padding: 14px; border: none; border-radius: 11px;
            cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
            box-shadow: 0 4px 18px rgba(240,92,20,0.35);
            transition: background 0.2s, transform 0.15s;
            margin-top: 12px; letter-spacing: -0.01em;
        }

        .btn-claim:hover { background: var(--orange-dark); transform: translateY(-1px); }
        .btn-claim svg { width: 17px; height: 17px; }

        .secure-note {
            display: flex; align-items: center; justify-content: center; gap: 5px;
            font-size: 0.7rem; color: var(--ink-soft); margin-top: 9px;
        }

        .secure-note svg { width: 11px; height: 11px; }

        /* ── SUCCESS ── */
        .success { display: none; flex-direction: column; align-items: center; justify-content: center; text-align: center; flex: 1; padding: 20px 0; }
        .success.active { display: flex; animation: slideIn 0.4s ease both; }

        .success-icon {
            width: 64px; height: 64px; background: var(--green-bg);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            margin-bottom: 18px;
        }

        .success-icon svg { width: 28px; height: 28px; color: var(--green); }

        .success h3 {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-size: 1.5rem; font-weight: 800;
            letter-spacing: -0.025em; margin-bottom: 10px;
        }

        .success p { font-size: 0.85rem; color: var(--ink-mid); line-height: 1.6; max-width: 270px; margin-bottom: 20px; }

        .success-bonus {
            background: var(--orange-light); border: 1px solid rgba(240,92,20,0.2);
            border-radius: 12px; padding: 14px 28px; margin-bottom: 20px;
        }

        .success-bonus-label { font-size: 0.68rem; font-weight: 700; color: var(--orange-dark); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 3px; }

        .success-bonus-amt {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-weight: 800; font-size: 2rem; color: var(--orange); letter-spacing: -0.03em;
        }

        .success-bonus-note { font-size: 0.68rem; color: var(--ink-soft); margin-top: 2px; }

        .btn-ghost {
            background: none; border: 1.5px solid var(--line);
            border-radius: 10px; padding: 9px 22px;
            font-family: 'DM Sans', sans-serif; font-size: 0.83rem;
            color: var(--orange); cursor: pointer; font-weight: 500;
            transition: border-color 0.2s, background 0.2s;
        }

        .btn-ghost:hover { border-color: var(--orange); background: var(--orange-light); }

        /* ── FOOTER ── */
        .footer {
            border-top: 1px solid var(--line); padding: 28px 0;
            background: var(--white);
        }

        .footer-inner {
            max-width: 1100px; margin: 0 auto; padding: 0 40px;
            display: flex; justify-content: space-between; align-items: center;
            flex-wrap: wrap; gap: 16px;
        }

