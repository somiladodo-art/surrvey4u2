                    <span class="earn-ind-label">Typical pay-per-survey in this category</span>
                    <span class="earn-ind-val" id="ei4v"></span>
                </div>
                <button class="btn-next" id="n4" onclick="next(4,5)">
                    Continue
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </div>

            <!-- ══ Q5: TIME ══ -->
            <div class="q-step" id="q5">
                <div class="q-number">Question 5 / 5</div>
                <div class="q-text">How much free time can you spare each week?</div>
                <div class="q-sub">This helps us recommend the right number of surveys. You can always adjust later — even 30 minutes a week adds up.</div>
                <div class="opts">
                    <button class="opt" onclick="pick(this,5,'time','30 min',50,400)">
                        <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
                        <span class="opt-text">30 minutes or less</span>
                        <span class="opt-check"><svg viewBox="0 0 10 10" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 5 4 7.5 8.5 2.5"/></svg></span>
                    </button>
                    <button class="opt" onclick="pick(this,5,'time','1–2 hrs',70,750)">
                        <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
                        <span class="opt-text">1 – 2 hours</span>
                        <span class="opt-check"><svg viewBox="0 0 10 10" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 5 4 7.5 8.5 2.5"/></svg></span>
                    </button>
                    <button class="opt" onclick="pick(this,5,'time','3–5 hrs',86,1400)">
                        <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
                        <span class="opt-text">3 – 5 hours</span>
                        <span class="opt-check"><svg viewBox="0 0 10 10" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 5 4 7.5 8.5 2.5"/></svg></span>
                    </button>
                    <button class="opt" onclick="pick(this,5,'time','5+ hrs',95,2000)">
                        <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
                        <span class="opt-text">5+ hours — I'm committed</span>
                        <span class="opt-check"><svg viewBox="0 0 10 10" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 5 4 7.5 8.5 2.5"/></svg></span>
                    </button>
                </div>
                <div class="reaction" id="r5">
                    <svg class="reaction-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    <span id="r5t"></span>
                </div>
                <div class="earn-indicator" id="ei5">
                    <span class="earn-ind-label">Your estimated monthly earning potential</span>
                    <span class="earn-ind-val" id="ei5v"></span>
                </div>
                <button class="btn-next" id="n5" onclick="showReveal()">
                    Calculate my earning potential
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </div>

            <!-- ══ REVEAL ══ -->
            <div class="reveal" id="reveal">
                <div class="reveal-head">
                    <div class="reveal-badge">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    </div>
                    <div class="reveal-h">You could earn up to<br><span class="amt" id="revAmt">R1,200</span>/month</div>
                    <div class="reveal-sub">Based on your profile and available surveys. Actual earnings vary — here's the breakdown of what you could unlock.</div>
                </div>

                <div class="breakdown">
                    <div class="bk-row"><span class="bk-label">Profile match score</span><span class="bk-val" id="bkScore">87%</span></div>
                    <div class="bk-row"><span class="bk-label">Panels you qualify for</span><span class="bk-val" id="bkPanels">4 of 4</span></div>
                    <div class="bk-row"><span class="bk-label">Surveys available right now</span><span class="bk-val" id="bkSurveys">12 surveys</span></div>
                    <div class="bk-divider"></div>
                    <div class="bk-total"><span>Welcome bonus (on first survey)</span><span class="bk-total-val" id="bkBonus">Up to R150</span></div>
                </div>

                <div class="disclaimer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    The welcome bonus is credited to your account once you complete your first survey. Earnings shown are estimates based on member averages and are not guaranteed.
                </div>

                <div class="match-label">Your matched survey panels</div>
                <div class="survey-cards" id="surveyCards"></div>

                <div class="reg-note">Sign up free to access these surveys and claim your bonus</div>
                <div class="reg-row">
                    <input class="reg-input" type="text" id="rfn" placeholder="First name">
                    <input class="reg-input" type="text" id="rln" placeholder="Last name">
                </div>
                <input class="reg-input" type="email" id="rem" placeholder="Email address" style="width:100%;margin-bottom:0;">

                <button class="btn-claim" onclick="claim()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    Create my free account &amp; see my surveys
                </button>

                <div class="secure-note">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Free forever · No credit card · Unsubscribe anytime
                </div>
            </div>

            <!-- ══ SUCCESS ══ -->
            <div class="success" id="success">
                <div class="success-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <h3>You're all set!</h3>
                <p>Check your inbox for your confirmation link. Activate your account and your welcome bonus will be credited after your first completed survey.</p>
                <div class="success-bonus">
                    <div class="success-bonus-label">Your welcome bonus</div>
                    <div class="success-bonus-amt" id="successAmt">Up to R150</div>
                    <div class="success-bonus-note">Credited after first survey completion</div>
                </div>
                <button class="btn-ghost" onclick="location.reload()">Start over</button>
            </div>

        </div>
    </div>
</div>

<!-- FOOTER -->
<footer class="footer">
    <div class="footer-inner">
        <div class="partners">
            <div class="partner"><div class="partner-icon" style="background:#E8F0FE;"><svg width="13" height="13" viewBox="0 0 24 24" fill="#4285F4"><circle cx="12" cy="12" r="10"/></svg></div><span class="partner-name">Toluna</span></div>
            <div class="partner"><div class="partner-icon" style="background:#EDE9FE;"><svg width="13" height="13" viewBox="0 0 24 24" fill="#7C3AED"><path d="M12 2L2 7l10 5 10-5-10-5z"/></svg></div><span class="partner-name">Valued Opinions</span></div>
            <div class="partner"><div class="partner-icon" style="background:#FDE8F0;"><svg width="13" height="13" viewBox="0 0 24 24" fill="#EC4899"><circle cx="12" cy="12" r="10"/></svg></div><span class="partner-name">LifePoints</span></div>
            <div class="partner"><div class="partner-icon" style="background:#ECFDF5;"><svg width="13" height="13" viewBox="0 0 24 24" fill="#10B981"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div><span class="partner-name">OpinionWorld</span></div>
        </div>
        <div class="legal"><span>&copy; 2026 Surveys For You</span><a href="#">Privacy Policy</a><a href="#">Terms of Service</a></div>
    </div>
</footer>

<script>
    // ── DATA ──
    const A = {}; // answers store: { key: { val, score, earn } }
    const TOTAL = 5;

    const REACTIONS = {
        age: {
            'Under 25':  "Youth panels are growing fast — brands want Gen Z perspectives on everything from social media to financial products.",
            '25–34':     "The 25–34 bracket is the most sought-after demographic by South African brands this quarter. Strong match.",
            '35–49':     "Household decision-makers are in very high demand by FMCG and insurance brands. You'll access premium surveys.",
            '50+':       "Financial services and healthcare brands pay significantly more for your age group. Excellent earning potential."
        },
        occ: {
            'Professional / Manager': "Decision-maker profiles unlock B2B surveys that pay R60–R120 per session — some of the highest rates on the platform.",
            'Business owner':         "Business owners are a premium demographic. You'll qualify for exclusive finance, insurance, and B2B panels.",
            'Skilled worker':         "Skilled workers match well across FMCG, automotive, and technology panels — consistent survey availability.",
            'Student':                "Students access education, tech, and lifestyle panels. Great for building consistent weekly income around your schedule.",
            'Homemaker':              "Homemakers are in high demand for FMCG, food, and retail surveys — some of the highest-volume categories in SA.",
            'Unemployed':             "You qualify for our flexible track — surveys available 24/7 with no schedule requirements."
        },
        shop: {
            'Weekly or more':       "Frequent online shoppers are prime candidates for retail panels paying R50–R100 per survey. High match rate.",
            'A few times a month':  "Monthly shoppers match dozens of active FMCG and retail surveys currently open on our platform.",
            'Rarely':               "Even occasional shoppers provide valuable perspective — brands specifically seek balanced consumer viewpoints.",
            'Never':                "In-store shoppers are actually underrepresented in research panels — you'll qualify for specialist retail surveys."
        },
        cat: {
            'Finance':     "Finance & banking surveys pay the most per minute on our platform — typically R60–R120 for 15 minutes.",
            'Health':      "Health and wellness panels are the fastest-growing category in SA. Surveys open daily at R40–R80 each.",
            'Technology':  "Tech surveys are short, frequent and well-paid. Brands like Vodacom and Samsung sponsor regular studies.",
            'Food':        "Food and lifestyle surveys post daily across all four of our partner panels. Ideal for consistent income."
        },
        time: {
            '30 min':   "30 minutes a week is enough to complete 2–3 surveys and earn R200–R500 per month.",
            '1–2 hrs':  "1–2 hours per week unlocks our full survey library. Most members at this level earn R600–R1,100/month.",
            '3–5 hrs':  "At 3–5 hours per week, members typically earn R1,200–R2,000/month. We'll fill your queue daily.",
            '5+ hrs':   "Maximum commitment = maximum earnings. We'll reserve our highest-tier surveys for your queue first."
        }
    };

    const EARN_INDICATORS = {
        age: {
            'Under 25': 'R200–R600/month', '25–34': 'R700–R1,200/month',
            '35–49': 'R900–R1,600/month', '50+': 'R750–R1,300/month'
        },
        occ: {
            'Professional / Manager': '87% match rate', 'Business owner': '94% match rate',
            'Skilled worker': '72% match rate', 'Student': '61% match rate',
            'Homemaker': '68% match rate', 'Unemployed': '54% match rate'
        },
        shop: {
            'Weekly or more': '18 surveys available', 'A few times a month': '14 surveys available',
            'Rarely': '9 surveys available', 'Never': '7 surveys available'
        },
        cat: {
            'Finance': 'R60–R120 per survey', 'Health': 'R40–R80 per survey',
            'Technology': 'R50–R95 per survey', 'Food': 'R30–R65 per survey'
        },
        time: {
            '30 min': 'R200–R500/month', '1–2 hrs': 'R600–R1,100/month',
            '3–5 hrs': 'R1,200–R2,000/month', '5+ hrs': 'R2,000–R3,200/month'
        }
    };

    const SURVEY_PANELS = {
        'Finance':    { name: 'Valued Opinions — Finance',   meta: 'Finance & Insurance · 12–18 min', earn: 'R65–R110', bg: '#EDE9FE', ic: '#7C3AED' },
        'Health':     { name: 'LifePoints — Health',         meta: 'Health & Wellness · 10–15 min',   earn: 'R40–R80',  bg: '#FDE8F0', ic: '#EC4899' },
        'Technology': { name: 'Toluna — Technology',         meta: 'Tech & Gadgets · 8–12 min',       earn: 'R50–R95',  bg: '#E8F0FE', ic: '#4285F4' },
        'Food':       { name: 'OpinionWorld — Lifestyle',    meta: 'Food & Lifestyle · 10–20 min',    earn: 'R30–R65',  bg: '#ECFDF5', ic: '#10B981' }
    };

    const TICKERS = [
        '47 people from South Africa completed this quiz today',
        'A new survey paying R85 was just posted to the platform',
        'Members in Gauteng earned an average of R940 last month',
        '12 surveys are currently open and waiting for respondents',
        'Thabo from Johannesburg earned R1,240 last month',
        'Priya from Cape Town just claimed her welcome bonus'
    ];

    let tickerIdx = 0;
    setInterval(() => {
        tickerIdx = (tickerIdx + 1) % TICKERS.length;
        const el = document.getElementById('tickerText');
        el.style.opacity = '0';
        setTimeout(() => { el.textContent = TICKERS[tickerIdx]; el.style.opacity = '1'; }, 300);
    }, 4000);
    document.getElementById('tickerText').style.transition = 'opacity 0.3s';

    // ── QUIZ LOGIC ──
    function pick(btn, q, key, val, score, earn) {
        document.getElementById('q' + q).querySelectorAll('.opt').forEach(b => b.classList.remove('sel'));
        btn.classList.add('sel');
        A[key] = { val, score, earn };

        const rt = document.getElementById('r' + q + 't');
        rt.textContent = REACTIONS[key][val];
        document.getElementById('r' + q).classList.add('show');

        const ei = document.getElementById('ei' + q);
        document.getElementById('ei' + q + 'v').textContent = EARN_INDICATORS[key][val];
        ei.classList.add('show');

        setTimeout(() => document.getElementById('n' + q).classList.add('on'), 350);

        // Pixel: step interaction
        if (typeof fbq !== 'undefined') fbq('trackCustom', 'QuizStep', { step: q, answer: val });

        // Update left panel step indicators
        for (let i = 1; i <= 3; i++) {
            const el = document.getElementById('snum' + i);
            if (el && q >= i) el.classList.add('done');
        }
    }

    function next(from, to) {
        const curr = document.getElementById('q' + from);
        curr.classList.add('leaving');
        setTimeout(() => {
            curr.classList.remove('active', 'leaving');
            document.getElementById('q' + to).classList.add('active');
            updateProgress(to);
        }, 220);
    }

    function updateProgress(step) {
        const pips = document.getElementById('progPips').children;
        for (let i = 0; i < pips.length; i++) {
            pips[i].classList.remove('filled', 'active');
            if (i < step - 1) pips[i].classList.add('filled');
            else if (i === step - 1) pips[i].classList.add('active');
        }
        document.getElementById('progLabel').textContent = 'Question ' + step + ' of ' + TOTAL;
    }

    function calcScore() {
        const vals = Object.values(A);
        return Math.round(vals.reduce((s, a) => s + a.score, 0) / vals.length);
    }

    function calcEarn() {
        const timeEarn = A.time ? A.time.earn : 750;
        const catBoost = A.cat ? (A.cat.score / 100) : 0.75;
        const occBoost = A.occ ? (A.occ.score / 100) : 0.7;
        return Math.round(timeEarn * catBoost * occBoost);
    }

    function showReveal() {
        const curr = document.getElementById('q5');
        curr.classList.add('leaving');

        const score = calcScore();
        const earn = calcEarn();
        const panels = Math.min(4, Math.max(2, Math.round(score / 25)));
        const surveys = Math.round(score / 8);
        const bonus = score >= 80 ? 150 : score >= 65 ? 120 : 90;

        document.getElementById('revAmt').textContent = 'R' + earn.toLocaleString();
        document.getElementById('bkScore').textContent = score + '%';
        document.getElementById('bkPanels').textContent = panels + ' of 4';
        document.getElementById('bkSurveys').textContent = surveys + ' surveys';
        document.getElementById('bkBonus').textContent = 'Up to R' + bonus;
        document.getElementById('successAmt').textContent = 'Up to R' + bonus;

        // Build survey cards
        const cat = A.cat ? A.cat.val : 'Finance';
        const allCats = ['Finance', 'Health', 'Technology', 'Food'];
        const ordered = [cat, ...allCats.filter(c => c !== cat)].slice(0, panels);
        const container = document.getElementById('surveyCards');
        container.innerHTML = '';
        ordered.forEach(c => {
            const p = SURVEY_PANELS[c];
            container.innerHTML += `
                <div class="survey-card">
                    <div class="survey-card-icon" style="background:${p.bg};">
                        <svg viewBox="0 0 24 24" fill="none" stroke="${p.ic}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    </div>
                    <div class="survey-card-body">
                        <div class="survey-card-name">${p.name}</div>
                        <div class="survey-card-meta">${p.meta}</div>
                    </div>
                    <div class="survey-card-earn">${p.earn}<span>per survey</span></div>
                </div>`;
        });

        // Pixel: quiz complete
        if (typeof fbq !== 'undefined') {
            fbq('trackCustom', 'QuizComplete', { score, estimated_earn: earn });
            fbq('track', 'Lead');
        }

        setTimeout(() => {
            curr.classList.remove('active', 'leaving');
            document.getElementById('progLabel').textContent = 'Results ready';
            const pips = document.getElementById('progPips').children;
            for (let i = 0; i < pips.length; i++) pips[i].classList.add('filled');
            document.getElementById('reveal').classList.add('active');
        }, 220);
    }

    function claim() {
        const fn = document.getElementById('rfn').value.trim();
        const em = document.getElementById('rem').value.trim();
        let valid = true;

        ['rfn', 'rem'].forEach(id => {
            const el = document.getElementById(id);
            el.classList.remove('err');
            const bad = !el.value.trim() || (id === 'rem' && !el.value.includes('@'));
            if (bad) { el.classList.add('err'); valid = false; }
        });

        if (!valid) return;

        // Pixel: registration / CompleteRegistration
        if (typeof fbq !== 'undefined') {
            fbq('track', 'CompleteRegistration');
            fbq('trackCustom', 'BonusClaimed', { name: fn });
        }

        // BeMob redirect — open tracking link, then show success
        const bemob = 'https://fqln4.bemobtrcks.com/go/06ec63d4-8757-4962-9be7-e71e290b2375';
        const params = new URLSearchParams(window.location.search);
        const url = bemob
            + '?ad_id=' + (params.get('ad_id') || '')
            + '&adset_id=' + (params.get('adset_id') || '')
            + '&campaign_id=' + (params.get('campaign_id') || '')
            + '&ad_name=' + (params.get('ad_name') || '')
            + '&adset_name=' + (params.get('adset_name') || '')
            + '&campaign_name=' + (params.get('campaign_name') || '');

        window.open(url, '_blank');

        document.getElementById('reveal').classList.remove('active');
        document.getElementById('reveal').style.display = 'none';
        document.getElementById('progRow').style.display = 'none';
        document.getElementById('ticker').style.display = 'none';
        setTimeout(() => document.getElementById('success').classList.add('active'), 100);
    }
</script>
</body>
</html>
